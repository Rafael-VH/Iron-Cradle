<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <JobDef>
    <defName>IC_GoToIronCradle</defName>
    <label>go to iron cradle</label>
    <description>Go to an iron cradle for self-repair.</description>
    <driverClass>IronCradle.JobDriver_GoToIronCradle</driverClass>
    <reportString>going to iron cradle.</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
    <playerInterruptible>true</playerInterruptible>
    <checkOverrideOnDamage>Never</checkOverrideOnDamage>
  </JobDef>

  <JobDef>
    <defName>IC_RepairAtIronCradle</defName>
    <label>repairing at iron cradle</label>
    <description>Being repaired at the iron cradle.</description>
    <driverClass>IronCradle.JobDriver_RepairAtIronCradle</driverClass>
    <reportString>repairing at iron cradle.</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
    <playerInterruptible>true</playerInterruptible>
    <checkOverrideOnDamage>Never</checkOverrideOnDamage>
    <casualInterruptible>false</casualInterruptible>
  </JobDef>

</Defs>
